/******************************************************************************
Conversor de Temperatura: Leia uma temperatura em Celsius e converta para Fahrenheit usando
a fórmula: $F = (C \times 1.8) + 32$.

*******************************************************************************/

#include <stdio.h>

int main()
{
    float c,f;
    
    printf("Digite um valor em celsius");
    scanf("%f", &c);
    
    f = (c* 9/5)+32;
    printf("Em Fahrenheit ficar %.2f", f);
    return 0;
}
