#include <stdio.h>

int main() {
    int num1, num2, soma;

    // Lê os dois números inteiros
    printf("Digite o primeiro número: ");
    scanf("%d", &num1);
    
    printf("Digite o segundo número: ");
    scanf("%d", &num2);

    // Calcula a soma
    soma = num1 + num2;

    // Exibe o resultado
    printf("A soma de %d e %d é: %d\n", num1, num2, soma);

    return 0;
}
