/******************************************************************************
Cálculo de Área: Leia o raio de um círculo e calcule a área ($Area = 3.14 \times raio^2$).

*******************************************************************************/


#include <stdio.h>

int main()
{
    float area, raio;
    
    printf("Calcule a area de u circulo: ");
    scanf("%f", &raio);
    
    area = 3.14 * (raio * raio) ;
    
    printf("a area e : %.2f", area);
    
    return 0;
}
