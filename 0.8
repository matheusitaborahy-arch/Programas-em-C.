/******************************************************************************

Dobro e Triplo: Leia um número e exiba o seu dobro e o seu triplo.
Dica: Faça as operações diretamente dentro do printf ou em variáveis separadas.
*******************************************************************************/
#include <stdio.h>

int main()
{
    int a;
    printf("digite um numero: ");
    scanf("%i", &a);
    printf("o dobro de %i e %i e o triplo e %i",a, a *2, a * 3);

    return 0;
}
